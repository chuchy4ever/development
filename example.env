# Copy this file to .env and fill in your values.
# .env is gitignored — example.env is the committed template.

# Your host username (used for volume mounts and HOME inside container)
HOST_USER=youruser

# Absolute path to your home directory
HOST_HOME=/home/youruser

# Where CEOrchestration stores its SQLite DB and runtime state
CEO_DATA_DIR=/home/youruser/.ceo

# Absolute path to the claude CLI binary on the host
CEO_CLAUDE_BIN=/home/youruser/.nvm/versions/node/v24.14.1/bin/claude
